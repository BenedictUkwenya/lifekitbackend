{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/check-trials",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/cron/check-inactivity",
      "schedule": "0 10 * * 1"
    }
  ]
}